"""
Speech-to-text using pretrained ASR (Wav2Vec2 or Whisper).
"""
import numpy as np
import torch
from typing import Optional

# Use Wav2Vec2 for lighter load; switch to "openai/whisper-small" for better accuracy
DEFAULT_MODEL_ID = "facebook/wav2vec2-base-960h"


class SpeechToText:
    """ASR using Hugging Face transformers."""

    def __init__(self, model_id: str = DEFAULT_MODEL_ID, device: Optional[str] = None):
        from transformers import AutoModelForCTC, AutoProcessor

        self.device = device or ("cuda" if torch.cuda.is_available() else "cpu")
        self.processor = AutoProcessor.from_pretrained(model_id)
        self.model = AutoModelForCTC.from_pretrained(model_id).to(self.device)

    def transcribe(self, audio: np.ndarray, sample_rate: int = 16000) -> str:
        """
        Transcribe float32 audio to text.
        Resample to 16kHz if needed (Wav2Vec2 expects 16kHz).
        """
        if sample_rate != 16000:
            import scipy.signal
            num_samples = int(len(audio) * 16000 / sample_rate)
            audio = scipy.signal.resample(audio, num_samples)
        inputs = self.processor(
            audio, sampling_rate=16000, return_tensors="pt", padding=True
        )
        inputs = {k: v.to(self.device) for k, v in inputs.items()}
        with torch.no_grad():
            logits = self.model(**inputs).logits
        ids = torch.argmax(logits, dim=-1)[0]
        return self.processor.decode(ids, skip_special_tokens=True).strip()
